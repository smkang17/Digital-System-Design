module tb_Timer;
  reg clk, reset, start, add_10m;
  wire clk_sec;
  wire [3:0] A, B, C, D;
  wire [6:0] seg1, seg2, seg3, seg4;
  Timer project3700(clk, clk_sec, reset, start, add_10m, A, B, C, D, seg1, seg2, seg3, seg4);
  initial begin
    clk = 0;
    forever #10 clk = ~clk; 
  end
  
  initial begin
    reset = 0;
    start = 0;
    add_10m = 0;

    #10000;
    reset = 1;
    add_10m = 1;
  end
endmodule
